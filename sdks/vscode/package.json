{
  "name": "technocodex",
  "displayName": "TechnocodeX",
  "description": "TechnocodeX AI coding assistant for VS Code",
  "version": "1.0.0",
  "publisher": "prabhasingh",
  "repository": {
    "type": "git",
    "url": "https://github.com/anomalyco/opencode"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "opencode.openTerminal",
        "title": "Open TechnocodeX",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "opencode.openNewTerminal",
        "title": "Open TechnocodeX New Session",
        "icon": {
          "light": "images/button-dark.svg",
          "dark": "images/button-light.svg"
        }
      },
      {
        "command": "opencode.addFilepathToTerminal",
        "title": "Add Filepath to Terminal"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "opencode.openNewTerminal",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "opencode.openTerminal",
        "title": "Run TechnocodeX",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "win": "ctrl+shift+t",
        "linux": "ctrl+shift+t"
      },
      {
        "command": "opencode.openNewTerminal",
        "title": "Run TechnocodeX New Session",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "win": "ctrl+alt+t",
        "linux": "ctrl+alt+t"
      },
      {
        "command": "opencode.addFilepathToTerminal",
        "title": "opencode: Insert At-Mentioned",
        "key": "cmd+alt+k",
        "mac": "cmd+alt+k",
        "win": "ctrl+alt+K",
        "linux": "ctrl+alt+K"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.js",
    "build": "node esbuild.js",
    "package": "npx @vscode/vsce package -o dist/technocodex-1.0.0.vsix --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.94.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
